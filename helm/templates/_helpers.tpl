{{/*
Expand the name of the chart.
*/}}
{{- define "aigis.name" -}}
{{- default .Chart.Name .Values.nameOverride | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
Create a default fully qualified app name.
We truncate at 63 chars because some Kubernetes name fields are limited to this (by the DNS naming spec).
If release name contains chart name it will be used as a full name.
*/}}
{{- define "aigis.fullname" -}}
{{- if .Values.fullnameOverride }}
{{- .Values.fullnameOverride | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- $name := default .Chart.Name .Values.nameOverride }}
{{- if contains $name .Release.Name }}
{{- .Release.Name | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- printf "%s-%s" .Release.Name $name | trunc 63 | trimSuffix "-" }}
{{- end }}
{{- end }}
{{- end }}

{{/*
Create chart label.
*/}}
{{- define "aigis.chart" -}}
{{- printf "%s-%s" .Chart.Name .Chart.Version | replace "+" "_" | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
Common labels.
*/}}
{{- define "aigis.labels" -}}
helm.sh/chart: {{ include "aigis.chart" . }}
{{ include "aigis.selectorLabels" . }}
{{- if .Chart.AppVersion }}
app.kubernetes.io/version: {{ .Chart.AppVersion | quote }}
{{- end }}
app.kubernetes.io/managed-by: {{ .Release.Service }}
{{- end }}

{{/*
Selector labels.
*/}}
{{- define "aigis.selectorLabels" -}}
app.kubernetes.io/name: {{ include "aigis.name" . }}
app.kubernetes.io/instance: {{ .Release.Name }}
app.kubernetes.io/component: backend
{{- end }}

{{/*
Service account name.
*/}}
{{- define "aigis.serviceAccountName" -}}
{{- if .Values.serviceAccount.create }}
{{- default (include "aigis.fullname" .) .Values.serviceAccount.name }}
{{- else }}
{{- default "default" .Values.serviceAccount.name }}
{{- end }}
{{- end }}

{{/*
CNPG cluster name.
*/}}
{{- define "aigis.cnpgClusterName" -}}
{{- printf "%s-postgres" (include "aigis.fullname" .) | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
Name of the secret holding the DATABASE_URL.
- External mode  → secret created by this chart (or existing secret)
- CNPG mode      → the app secret generated by CloudNativePG
*/}}
{{- define "aigis.dbSecretName" -}}
{{- if .Values.database.external.enabled -}}
  {{- if .Values.database.external.existingSecret -}}
    {{- .Values.database.external.existingSecret.name -}}
  {{- else -}}
    {{- printf "%s-db-external" (include "aigis.fullname" .) -}}
  {{- end -}}
{{- else -}}
  {{- printf "%s-app" (include "aigis.cnpgClusterName" .) -}}
{{- end -}}
{{- end -}}

{{/*
Key inside the db url secret.
*/}}
{{- define "aigis.dbSecretKey" -}}
{{- if .Values.database.external.enabled -}}
  {{- if .Values.database.external.existingSecret -}}
    {{- .Values.database.external.existingSecret.key -}}
  {{- else -}}
    url
  {{- end -}}
{{- else -}}
  uri
{{- end -}}
{{- end -}}

{{/*
Image tag (defaults to chart appVersion).
*/}}
{{- define "aigis.imageTag" -}}
{{- .Values.image.tag | default .Chart.AppVersion }}
{{- end }}

{{/*
Name of the secret and key holding REDIS_URL.
- External mode (redis.external.enabled=true)
    → user-supplied secret or a secret created by this chart
- Valkey sub-chart mode
    → compute the URL from Valkey service name (no secret needed; pass as env var)
*/}}
{{- define "aigis.redisSecretName" -}}
{{- if .Values.redis.external.enabled -}}
  {{- if .Values.redis.external.existingSecret -}}
    {{- .Values.redis.external.existingSecret.name -}}
  {{- else -}}
    {{- printf "%s-redis-external" (include "aigis.fullname" .) -}}
  {{- end -}}
{{- end -}}
{{- end -}}

{{- define "aigis.redisSecretKey" -}}
{{- if .Values.redis.external.enabled -}}
  {{- if .Values.redis.external.existingSecret -}}
    {{- .Values.redis.external.existingSecret.key -}}
  {{- else -}}
    url
  {{- end -}}
{{- end -}}
{{- end -}}

{{/*
Built-in Valkey service name (primary standalone).
Bitnami Valkey names the primary service: <release>-valkey-primary
*/}}
{{- define "aigis.valkeyServiceName" -}}
{{- printf "%s-valkey" .Release.Name -}}
{{- end -}}

{{/*
Name of the secret holding the SMTP password.
- existingSecret mode  → user-supplied secret
- default              → secret created by this chart
*/}}
{{- define "aigis.smtpSecretName" -}}
{{- if .Values.app.smtp.existingSecret -}}
  {{- .Values.app.smtp.existingSecret.name -}}
{{- else -}}
  {{- printf "%s-smtp" (include "aigis.fullname" .) -}}
{{- end -}}
{{- end -}}

{{/*
Key inside the SMTP password secret.
*/}}
{{- define "aigis.smtpSecretPasswordKey" -}}
{{- if .Values.app.smtp.existingSecret -}}
  {{- .Values.app.smtp.existingSecret.passwordKey | default "password" -}}
{{- else -}}
  password
{{- end -}}
{{- end -}}
