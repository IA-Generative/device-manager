{
  "realm": "myapp",
  "enabled": true,
  "displayName": "My App",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "otpSupportedApplications": ["FreeOTP", "Google Authenticator"],
  "clients": [
    {
      "clientId": "device-service",
      "name": "Device Service",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "device-cli",
      "name": "Device CLI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8080/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:8080/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8080",
        "http://127.0.0.1:5173",
        "http://127.0.0.1:8080"
      ],
      "attributes": {
        "acr.loa.map": "{\"urn:keycloak:acr:mfa\":\"2\",\"urn:keycloak:acr:basic\":\"1\"}"
      },
      "protocolMappers": [
        {
          "name": "device_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "config": {
            "claim.name": "device_id",
            "jsonType.label": "String",
            "user.session.note": "device_id",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "acr loa level",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-acr-mapper",
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Doe",
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Smith",
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ]
    }
  ],
  "browserFlow": "browser with step-up",
  "authenticationFlows": [
    {
      "alias": "browser with step-up",
      "description": "Browser flow with conditional step-up MFA",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": false,
          "authenticator": "auth-cookie",
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticatorFlow": true,
          "flowAlias": "browser with step-up - forms",
          "requirement": "ALTERNATIVE",
          "priority": 20
        }
      ]
    },
    {
      "alias": "browser with step-up - forms",
      "description": "Username+password then conditional OTP",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": false,
          "authenticator": "auth-username-password-form",
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticatorFlow": true,
          "flowAlias": "step-up conditional otp",
          "requirement": "CONDITIONAL",
          "priority": 20
        }
      ]
    },
    {
      "alias": "step-up conditional otp",
      "description": "Conditional OTP for step-up (LOA 2)",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": false,
          "authenticator": "conditional-level-of-authentication",
          "requirement": "REQUIRED",
          "priority": 10,
          "authenticatorConfig": {
            "alias": "loa-condition-config",
            "config": {
              "loa-condition-level": "2",
              "loa-max-age": "0"
            }
          }
        },
        {
          "authenticatorFlow": false,
          "authenticator": "auth-otp-form",
          "requirement": "REQUIRED",
          "priority": 20
        }
      ]
    }
  ]
}